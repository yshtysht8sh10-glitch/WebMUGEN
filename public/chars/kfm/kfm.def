; ここにキャラ情報を書いてください
[Info]
name = "Kung Fu Man"        ;キャラの名前
displayname = "Kung Fu Man" ;表示されるキャラの名前
versiondate = 11,22,2000    ;キャラの更新情報
mugenversion = 11,22,2000   ;キャラが動くmugenのバージョン
author = "Elecbyte"         ;キャラの製作者名
pal.defaults = 6,3,4,2      ;敵としてでるキャラのパレット

; Files for the player
[Files]
cmd     = kfm.cmd   ;キャラのコマンド
cns     = kfm.cns   ;キャラのプログラム
st      = kfm.cns   ;キャラのプログラム
stcommon = common1.cns 
sprite  = kfm.sff   ;キャラの絵
anim    = kfm.air   ;キャラの動き
sound   = kfm.snd   ;キャラの音
pal1    = kfm6.act  ;キャラの色（最大１２個）
pal2    = kfm4.act
pal3    = kfm2.act
pal4    = kfm5.act
pal5    = kfm3.act
pal6    = kfm.act